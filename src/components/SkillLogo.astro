---
type Props = {
  name: string;
};

const { name } = Astro.props;
const key = name.toLowerCase();
const label = `${name} logo`;

const iconMap = [
  {
    match: "java",
    id: "java",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg"
  },
  {
    match: "spring",
    id: "spring",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/spring/spring-original.svg"
  },
  {
    match: "mysql",
    id: "mysql",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg"
  },
  {
    match: "postgres",
    id: "postgresql",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg"
  },
  {
    match: "mongo",
    id: "mongodb",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg"
  },
  {
    match: "redisson",
    id: "redisson",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/redis/redis-original.svg"
  },
  {
    match: "redis",
    id: "redis",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/redis/redis-original.svg"
  },
  {
    match: "aws",
    id: "aws",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/amazonwebservices/amazonwebservices-original-wordmark.svg"
  },
  {
    match: "docker",
    id: "docker",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg"
  },
  {
    match: "figma",
    id: "figma",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg"
  },
  {
    match: "github",
    id: "github",
    src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg"
  },
  { match: "confluence", id: "confluence", src: "https://img.icons8.com/fluency/48/confluence.png" },
  { match: "notion", id: "notion", src: "https://cdn.simpleicons.org/notion/000000/ffffff" },
  { match: "jira", id: "jira", src: "https://cdn.simpleicons.org/jira" },
  { match: "slack", id: "slack", src: "https://img.icons8.com/color/48/slack-new.png" },
  { match: "querydsl", id: "querydsl", src: "https://img.icons8.com/fluency/48/database.png" },
  { match: "jacoco", id: "jacoco", src: "https://www.jacoco.org/jacoco/trunk/doc/resources/report.gif" },
  { match: "google analytics", id: "google-analytics", src: "https://img.icons8.com/color/48/google-analytics.png" },
  {
    match: "ms clarity",
    id: "ms-clarity",
    src: "https://img.icons8.com/external-creatype-glyph-colourcreatype/64/external-clarity-tools-design-creatype-glyph-colourcreatype.png"
  },
  {
    match: "microsoft clarity",
    id: "microsoft-clarity",
    src: "https://img.icons8.com/external-creatype-glyph-colourcreatype/64/external-clarity-tools-design-creatype-glyph-colourcreatype.png"
  },
  {
    match: "clarity",
    id: "clarity",
    src: "https://img.icons8.com/external-creatype-glyph-colourcreatype/64/external-clarity-tools-design-creatype-glyph-colourcreatype.png"
  }
];

const matchedIcon = iconMap.find((icon) => key.includes(icon.match));
---

{
  matchedIcon ? (
    <span class="skill-logo brand-logo" data-logo={matchedIcon.id} aria-label={label} role="img">
      <img src={matchedIcon.src} alt="" loading="lazy" />
    </span>
  ) : (
    <span class="skill-logo generic" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 4 26.4 10v12L16 28 5.6 22V10L16 4Z" />
        <text x="16" y="19">{name.slice(0, 2).toUpperCase()}</text>
      </svg>
    </span>
  )
}
