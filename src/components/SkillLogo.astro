---
type Props = {
  name: string;
};

const { name } = Astro.props;
const key = name.toLowerCase();
const label = `${name} logo`;
---

{
  key.includes("spring") ? (
    <span class="skill-logo spring" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 2.8 27.4 9.4v13.2L16 29.2 4.6 22.6V9.4L16 2.8Z" />
        <path class="logo-line" d="M16 9.2v7.2" />
        <path class="logo-line" d="M20.2 11.8a6 6 0 1 1-8.4 0" />
      </svg>
    </span>
  ) : key.includes("java") ? (
    <span class="skill-logo java" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path class="steam" d="M14.2 5.2c3.4 2.3-3.2 3.9.4 6.4" />
        <path class="steam" d="M18.6 4.4c3.9 2.8-3.4 4.7.2 7.6" />
        <path d="M9 15.7h12.2c0 5.2-2.5 8-6.1 8S9 20.9 9 15.7Z" />
        <path d="M21 17h2.4c0 2.4-1.2 3.7-3.2 4" />
        <path class="saucer" d="M8.2 25.7h14.6" />
      </svg>
    </span>
  ) : key.includes("mysql") ? (
    <span class="skill-logo mysql" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M6.2 19.7c4.8-6 11-7.7 18.5-5.1-1.1-2.8-4-5-8.2-5.2-5.7-.3-9.9 3.4-10.3 10.3Z" />
        <path class="logo-line" d="M19.5 13.8c2.5-.8 4.7-.5 6.6.8" />
      </svg>
    </span>
  ) : key.includes("postgre") ? (
    <span class="skill-logo postgres" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M10.2 22.4c-3-2.3-4.2-6.5-2.6-10.1 1.8-4 6.6-5.8 10.9-4 4.5 1.9 6.4 6.4 4.9 10.8-.8 2.3-2.5 4.1-4.7 5.1" />
        <path class="logo-line" d="M17.8 14.4c1.7 2.4 2.2 5.3 1 9.8" />
        <circle cx="13.6" cy="14.2" r="1.4" />
      </svg>
    </span>
  ) : key.includes("mongo") ? (
    <span class="skill-logo mongo" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16.2 3.8c5 5.1 6.2 10.7 3.1 16.7-1.1 2.2-2.4 4-3.1 6.9-.8-2.9-2.1-4.7-3.2-6.9-3.1-6-1.9-11.6 3.2-16.7Z" />
        <path class="logo-line" d="M16.2 8.2v19.2" />
      </svg>
    </span>
  ) : key.includes("redis") ? (
    <span class="skill-logo redis" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M6 11.5 16 7l10 4.5-10 4.6L6 11.5Z" />
        <path d="M6 16.1 16 20.6l10-4.5" />
        <path d="M6 20.8 16 25.3l10-4.5" />
      </svg>
    </span>
  ) : key.includes("aws") ? (
    <span class="skill-logo aws" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <text x="5" y="17">aws</text>
        <path class="smile" d="M9 21.3c4.6 2.6 9.6 2.4 14.8-.4" />
        <path class="smile" d="M22.5 20.9h3.2l-1.5 2.8" />
      </svg>
    </span>
  ) : key.includes("docker") ? (
    <span class="skill-logo docker" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M8 16.2h17.8c-.5 4.5-3.7 7.1-9.4 7.1-4.7 0-7.8-2.5-8.4-7.1Z" />
        <path d="M10 12h3v3h-3zm4 0h3v3h-3zm4 0h3v3h-3zm-4-4h3v3h-3z" />
      </svg>
    </span>
  ) : key.includes("github") ? (
    <span class="skill-logo github" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 5.4a10.6 10.6 0 0 0-3.4 20.7c.5.1.7-.2.7-.5v-2c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 2.9.9.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.1-4.7-5.2 0-1.1.4-2.1 1.1-2.8-.1-.3-.5-1.4.1-2.8 0 0 .9-.3 2.9 1.1.8-.2 1.7-.3 2.6-.3.9 0 1.8.1 2.6.3 2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.8.7.7 1.1 1.7 1.1 2.8 0 4.1-2.4 4.9-4.7 5.2.4.3.7.9.7 1.8v2.8c0 .3.2.6.7.5A10.6 10.6 0 0 0 16 5.4Z" />
      </svg>
    </span>
  ) : key.includes("figma") ? (
    <span class="skill-logo figma" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="13" cy="9" r="4" />
        <circle cx="19" cy="9" r="4" />
        <circle cx="13" cy="16" r="4" />
        <circle cx="19" cy="16" r="4" />
        <circle cx="13" cy="23" r="4" />
      </svg>
    </span>
  ) : (
    <span class="skill-logo generic" aria-label={label} role="img">
      <svg viewBox="0 0 32 32" aria-hidden="true">
        <path d="M16 4 26.4 10v12L16 28 5.6 22V10L16 4Z" />
        <text x="16" y="19">{name.slice(0, 2).toUpperCase()}</text>
      </svg>
    </span>
  )
}
