---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const { title, description, role, card } = project.data;
const slug = project.id.replace(/\.md$/, "");
const isPhonePreview = card.device === "phones";
const previewStyle = [
  card.imageFit && `--card-image-fit: ${card.imageFit}`,
  card.imagePosition && `--card-image-position: ${card.imagePosition}`,
  card.screenRatio && `--card-screen-ratio: ${card.screenRatio}`
].filter(Boolean).join("; ");
---

<a class="project-card" href={`/projects/${slug}/`}>
  <div class="project-card-content">
    <div class="project-card-copy">
      <h3>{title}</h3>
      <p class="project-description">{description}</p>
    </div>
    <div class="meta-row">
      <span class="tag">{card.badge}</span>
      <span class="tag">{role}</span>
    </div>
  </div>
  <span class:list={["project-card-media", isPhonePreview ? "phone-media" : "laptop-media"]} style={previewStyle}>
    {
      isPhonePreview ? (
        <span class="phone-preview" aria-hidden="true">
          <span class="phone-device phone-device-back">
            <span class="phone-speaker"></span>
            <span class="phone-screen">
              <img class="project-card-image" src={card.secondaryImage ?? card.image} alt="" loading="lazy" />
            </span>
          </span>
          <span class="phone-device phone-device-front">
            <span class="phone-speaker"></span>
            <span class="phone-screen">
              <img class="project-card-image" src={card.image} alt="" loading="lazy" />
            </span>
          </span>
        </span>
      ) : (
        <span class="laptop-preview" aria-hidden="true">
          <span class="laptop-lid">
            <span class="laptop-camera"></span>
            <span class="laptop-screen">
              <img class="project-card-image" src={card.image} alt="" loading="lazy" />
            </span>
          </span>
          <span class="laptop-hinge"></span>
          <span class="laptop-base"></span>
          <span class="laptop-shadow"></span>
        </span>
      )
    }
    <span class="sr-only">
      {card.imageAlt}
      {card.secondaryImageAlt ? `, ${card.secondaryImageAlt}` : ""}
    </span>
  </span>
</a>
