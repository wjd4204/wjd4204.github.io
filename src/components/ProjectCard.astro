---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const { title, description, role, status, image, imageAlt, hoverImage, hoverImageAlt } =
  project.data;
---

<a class="project-card" href={`/projects/${project.id}/`}>
  <div class="project-card-content">
    <div class="project-card-copy">
      <h3>{title}</h3>
      <p class="project-description">{description}</p>
    </div>
    <div class="meta-row">
      <span class="tag">{status}</span>
      <span class="tag">{role}</span>
    </div>
  </div>
  <span class="project-card-media">
    <img class="project-card-image primary" src={image} alt={imageAlt} loading="lazy" />
    <img class="project-card-image secondary" src={hoverImage} alt={hoverImageAlt} loading="lazy" />
  </span>
</a>
