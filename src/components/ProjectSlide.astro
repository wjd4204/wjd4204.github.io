---
type Props = {
  index: number;
  keyLabel: string;
  title: string;
  image: string;
  imageAlt: string;
  imageLink?: string;
  imageLinkLabel?: string;
  body: string[];
  points?: string[];
  problem?: string[];
  cause?: string[];
  solution?: string[];
  result?: string[];
  lesson?: string[];
};

const {
  index,
  keyLabel,
  title,
  image,
  imageAlt,
  imageLink,
  imageLinkLabel,
  body,
  points = [],
  problem,
  cause,
  solution,
  result,
  lesson
} = Astro.props;

const escapeHtml = (value: string) =>
  value.replace(/[&<>"']/g, (character) => {
    const entities: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;"
    };

    return entities[character];
  });

const renderBoldText = (value: string) =>
  escapeHtml(value).replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");

const renderInlineText = (value: string) => renderBoldText(value);
const renderSoftBreakText = (value: string) =>
  value.split(/\n/).map(renderInlineText).join("<br />");
const unorderedMarkerPattern = /^(\s*)[-*]\s+(.+)$/;
const orderedMarkerPattern = /^(\s*)\d+[.)]\s+(.+)$/;

type RenderBlock = string | ListBlock;

type ListBlock = {
  type: "ul" | "ol";
  indent: number;
  items: ListItem[];
};

type ListItem = {
  content: string;
  children: ListBlock[];
};

const renderListBlock = (list: ListBlock): string => {
  const renderedItems = list.items
    .map((item) => {
      const children = item.children.map(renderListBlock).join("");
      return "<li>" + renderSoftBreakText(item.content) + children + "</li>";
    })
    .join("");

  return "<" + list.type + ">" + renderedItems + "</" + list.type + ">";
};

const renderTroubleshootingText = (value: string) => {
  const lines = value.split(/\n/);
  const blocks: RenderBlock[] = [];
  const listStack: ListBlock[] = [];
  let paragraphLines: string[] = [];

  const flushParagraph = () => {
    if (paragraphLines.length === 0) return;
    blocks.push(`<p>${paragraphLines.map(renderSoftBreakText).join("<br />")}</p>`);
    paragraphLines = [];
  };

  const appendList = (type: "ul" | "ol", indent: number, content: string) => {
    flushParagraph();

    while (listStack.length > 0 && indent < listStack[listStack.length - 1].indent) {
      listStack.pop();
    }

    if (
      listStack.length > 0 &&
      indent === listStack[listStack.length - 1].indent &&
      type !== listStack[listStack.length - 1].type
    ) {
      listStack.pop();
    }

    let currentList = listStack[listStack.length - 1];

    if (!currentList || indent > currentList.indent || type !== currentList.type) {
      const nextList: ListBlock = {
        type,
        indent,
        items: []
      };

      if (currentList && indent > currentList.indent && currentList.items.length > 0) {
        currentList.items[currentList.items.length - 1].children.push(nextList);
      } else {
        blocks.push(nextList);
      }

      listStack.push(nextList);
      currentList = nextList;
    }

    currentList.items.push({
      content,
      children: []
    });
  };

  lines.forEach((line) => {
    if (line.trim().length === 0) {
      listStack.length = 0;
      flushParagraph();
      return;
    }

    const unorderedMatch = line.match(unorderedMarkerPattern);
    const orderedMatch = line.match(orderedMarkerPattern);

    if (unorderedMatch) {
      appendList("ul", unorderedMatch[1].length, unorderedMatch[2]);
      return;
    }

    if (orderedMatch) {
      appendList("ol", orderedMatch[1].length, orderedMatch[2]);
      return;
    }

    const currentList = listStack[listStack.length - 1];
    const currentItem = currentList?.items[currentList.items.length - 1];

    if (currentItem) {
      currentItem.content += "\n" + line.trim();
      return;
    }

    listStack.length = 0;
    paragraphLines.push(line.trim());
  });

  flushParagraph();

  return blocks.map((block) => (typeof block === "string" ? block : renderListBlock(block))).join("");
};

const hasStructuredSections = Boolean(problem || cause || solution || result || lesson);
const slideSections = [
  {
    label: "문제 상황",
    items: problem ?? (hasStructuredSections ? [] : body.slice(0, 1)),
    tone: "text"
  },
  {
    label: "원인 분석",
    items: cause ?? (hasStructuredSections ? [] : body.slice(1, 2)),
    tone: "text"
  },
  {
    label: "해결 과정",
    items: solution ?? (hasStructuredSections ? [] : body.slice(2)),
    tone: "text"
  },
  {
    label: "성과",
    items: result ?? (hasStructuredSections ? [] : points),
    tone: "points"
  },
  {
    label: "배운 점",
    items: lesson ?? [],
    tone: "points"
  }
].filter((section) => section.items.length > 0);
---

<section class="project-slide" aria-labelledby={`slide-${index}`}>
  <div class="slide-media">
    <img src={image} alt={imageAlt} loading={index === 1 ? "eager" : "lazy"} />
    {
      imageLink && (
        <a class="slide-media-link" href={imageLink} target="_blank" rel="noreferrer">
          {imageLinkLabel ?? "Link"}
        </a>
      )
    }
  </div>
  <div class="slide-copy">
    <p class="slide-index">{String(index).padStart(2, "0")} / {keyLabel}</p>
    <h2 id={`slide-${index}`}>{title}</h2>
    <div class="slide-detail">
      {
        slideSections.map((section) => (
          <section class:list={["slide-section", section.tone === "points" && "slide-section-points"]}>
            <h3>{section.label}</h3>
            {
              section.tone === "points" ? (
                <ul class="slide-points">
                  {section.items.map((item) => <li set:html={renderBoldText(item)} />)}
                </ul>
              ) : (
                <div class="slide-body" set:html={section.items.map(renderTroubleshootingText).join("")} />
              )
            }
          </section>
        ))
      }
    </div>
  </div>
</section>
