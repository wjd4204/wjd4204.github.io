---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillLogo from "../components/SkillLogo.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const about = {
  name: "박정곤",
  university: "세종대학교(지능기전공학부 무인이동체공학과)",
  phone: "📞 +82 10-4204-3473",
  tistory: "https://wjd4204.tistory.com",
  github: "https://github.com/wjd4204",
  introduction:
    "사용자가 되어 생각하고, 개발자로 해결하는 박정곤입니다."
};

const aboutIntroductions = [
  "사용자가 불편함을 느끼는 순간, 저는 개발자이기 전에 한 명의 사용자가 되어 먼저 생각합니다. 이 관점을 바탕으로 대학생과 기업을 연결하는 외주 매칭 플랫폼 “SOUF”를 총괄 설계하고 운영하며 서비스가 사용자에게 닿는 전 과정을 직접 경험했습니다. Dead Click 분석을 통해 회원가입 흐름을 재설계하여 이탈률을 5%대로 감소시키는 실질적인 수치를 달성했습니다. 이처럼 사용자의 시선으로 문제를 발견하고, 개발자의 언어로 해결하는 방식으로 성장하고 있습니다. 저는 AI를 단순 도구가 아닌 개발 역량을 확장하고 함께 성장하는 파트너로 대합니다. AI와의 반복적인 협업 속에서 저는 문제를 구조화하는 능력을 향상시키는 동시에 AI는 저의 맥락을 학습하며 제안의 정확도가 높아졌습니다. AI 생태계가 빠르게 진화할수록 AI를 잘 활용하는 개발자가 더 나은 서비스를 만든다고 생각하며 앞으로도 성장해 나가겠습니다."
];

const stacks = [
  {
    group: "Language",
    items: ["Java 17"]
  },
  {
    group: "Framework / Library",
    items: ["Spring Boot", "Spring Data JPA", "Spring Cache", "Querydsl"]
  },
  {
    group: "Database / Server",
    items: ["MySQL", "PostgreSQL", "MongoDB", "Redis", "AWS"]
  },
  {
    group: "Tools",
    items: ["Docker", "SQLTron", "DBeaver", "Figma"]
  },
  {
    group: "ETC",
    items: ["GitHub", "Notion", "Jira", "Slack"]
  }
];
---

<BaseLayout title="wjd4204 | Backend Developer">
  <section class="container hero" id="home">
    <div>
      <p class="eyebrow">사용자의 입장에서 움직이는 백엔드 개발자</p>
      <h1>
        <span>사용자가 되어 생각하고,</span>
        <span>개발자로 해결합니다.</span>
      </h1>
      <p class="lead">
        서비스의 흐름을 관찰하고 병목을 줄이며, 읽기 쉬운 API와 안정적인 데이터 구조를
        설계하는 데 집중합니다. 프로젝트를 통해 문제 정의, 기술 선택, 해결 과정을 기록합니다.
      </p>
      <div class="link-row" style="margin-top: 28px;">
        <a class="button" href="#projects">프로젝트 보기</a>
        <a class="button secondary" href="#about">소개 보기</a>
      </div>
    </div>
  </section>

  <section class="section about-section" id="about">
    <div class="container about-layout">
      <div class="about-heading">
        <p class="eyebrow">About me</p>
        <h2>{about.name}</h2>
        <p>{about.introduction}</p>
      </div>
      <div class="about-panel">
        <dl class="profile-list">
          <div>
            <dt>대학교</dt>
            <dd>{about.university}</dd>
          </div>
          <div>
            <dt>연락처</dt>
            <dd>{about.phone}</dd>
          </div>
          <div>
            <dt>Tistory</dt>
            <dd><a href={about.tistory}>{about.tistory}</a></dd>
          </div>
          <div>
            <dt>GitHub</dt>
            <dd><a href={about.github}>{about.github}</a></dd>
          </div>
        </dl>
      </div>
      <p class="about-intro">{aboutIntroductions[0]}</p>
    </div>
  </section>

  <section class="section skills-section" id="skills">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Tech stack</p>
          <h2>사용 가능한 기술 스택</h2>
        </div>
        <p>익숙한 도구를 나열하는 데서 멈추지 않고, 문제 상황에 맞는 이유를 함께 고민합니다.</p>
      </div>
      <div class="skill-accordion">
        {
          stacks.map((stackGroup) => (
            <details class="skill-panel">
              <summary>
                <span>{stackGroup.group}</span>
                <span class="summary-mark" aria-hidden="true">+</span>
              </summary>
              <div class="skill-panel-body">
                <div class="tag-list">
                  {
                    stackGroup.items.map((item) => (
                      <span class="tag skill-tag">
                        <SkillLogo name={item} />
                        <span>{item}</span>
                      </span>
                    ))
                  }
                </div>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section projects-section" id="projects">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected projects</p>
          <h2>Projects</h2>
        </div>
        <p>SOUF, TAVE Website, Synergy의 문제 정의와 백엔드 설계 판단을 슬라이드형 상세 페이지로 정리했습니다.</p>
      </div>
      <div class="grid">
        {projects.slice(0, 3).map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
