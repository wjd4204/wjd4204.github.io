---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillLogo from "../components/SkillLogo.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const about = {
  name: "박정곤",
  university: "세종대학교(지능기전공학부 무인이동체공학과)",
  phone: "+82 10-4204-3473",
  tistory: "https://gony-dev.tistory.com/",
  github: "https://github.com/wjd4204",
  introduction:
    "사용자의 눈으로 보고, 개발자의 손으로 풀어냅니다."
};

const aboutIntroductions = [
  {
    title: "[ 사용자의 시선으로 문제를 발견하는 실전 경험 ]",
    body: [
      "UX 개선은 직군을 가리지 않는 공통 과제라고 생각합니다. 그래서 저는 항상 데이터를 먼저 들여다봅니다.\n" +
      "Google Analytics로 사용자 행동을 분석하던 중, 회원가입 이탈률이 비정상적으로 높다는 것을 발견했습니다. 실제 사용자 테스트를 병행해 원인을 파악하고 가입 흐름을 재설계한 결과, 이탈률을 31%에서 5%대로 낮출 수 있었습니다.\n" +
      "MS Clarity로 방문자 행동 패턴을 분석했을 때는, 이미지 로딩 구간에서 병목이 발생한다는 것을 확인했습니다. 이미지 포맷을 WebP로 전환해 로딩 속도를 개선했습니다.\n" +
      "데이터를 근거로 문제를 발견하고, 사용자 경험으로 연결하는 일을 중요하게 생각하며 계속 성장하고 있습니다."
    ]
  }
];

const stacks = [
  {
    group: "Language",
    summary: "주력 언어와 런타임 이해를 바탕으로 안정적인 서버 코드를 작성합니다.",
    items: ["Java 17"]
  },
  {
    group: "Framework / Library",
    summary: "Spring 기반 API, 데이터 접근, 캐싱, 동적 쿼리 설계를 프로젝트에 맞게 선택합니다.",
    items: ["Spring Boot", "Spring Data JPA", "Spring Cache", "Querydsl"]
  },
  {
    group: "Database",
    summary: "관계형 데이터 모델링과 캐시/문서형 저장소를 문제 성격에 맞게 조합합니다.",
    items: ["MySQL", "PostgreSQL", "MongoDB", "Redis"]
  },
  {
    group: "Infra / Cloud",
    summary: "배포와 운영 환경을 고려해 컨테이너와 클라우드 기반 실행 환경을 다룹니다.",
    items: ["Docker", "AWS"]
  },
  {
    group: "ETC",
    summary: "협업과 의사결정 기록을 남기며, 문제 해결 과정을 팀과 공유합니다.",
    items: ["Notion", "Jira", "Confluence", "Slack"]
  }
];
---

<BaseLayout title="박정곤 | Backend Developer">
  <section class="container hero" id="home">
    <div class="hero-particles" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="hero-content">
      <p class="hero-kicker">Turning Ideas From Experience</p>
      <h1>
        <span>Park JeongGon</span>
      </h1>
      <p class="hero-role">Backend Developer Portfolio</p>
      <p class="lead">
        사용자의 불편함을 데이터로 발견하고, 안정적인 서버 구조와 근거 있는 기술 선택으로
        문제를 해결합니다.
      </p>
      <div class="link-row hero-actions">
        <a class="button" href="#projects">프로젝트 보기</a>
        <a class="button secondary" href="#about">소개 보기</a>
      </div>
      <a class="scroll-cue" href="#about" aria-label="About me 섹션으로 이동">
        <span>SCROLL</span>
        <span aria-hidden="true">⌄</span>
      </a>
    </div>
  </section>

  <section class="section about-section" id="about">
    <div class="container about-layout">
      <div class="about-heading">
        <span class="section-number">01.</span>
        <p class="eyebrow">About me</p>
        <h2>{about.name}</h2>
        <p>{about.introduction}</p>
      </div>
      <div class="about-panel">
        <dl class="profile-list">
          <div>
            <dt>🏫 대학교</dt>
            <dd>{about.university}</dd>
          </div>
          <div>
            <dt>📞 연락처</dt>
            <dd>{about.phone}</dd>
          </div>
          <div>
            <dt>📑 블로그</dt>
            <dd><a href={about.tistory}>{about.tistory}</a></dd>
          </div>
          <div>
            <dt>💻 GitHub</dt>
            <dd><a href={about.github}>{about.github}</a></dd>
          </div>
        </dl>
      </div>
      <div class="about-intro">
        {
          aboutIntroductions.map((intro) => (
            <section class="about-intro-block">
              <h3>{intro.title}</h3>
              {intro.body.map((paragraph) => <p>{paragraph}</p>)}
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section skills-section" id="skills">
    <div class="container section-frame">
      <div class="section-heading section-frame-heading">
        <span class="section-number">02.</span>
        <p class="eyebrow">Tech stack</p>
        <h2>기술 스택</h2>
        <p>익숙한 도구를 나열하는 데서 멈추지 않고, 문제 상황에 맞는 이유를 고민합니다.</p>
      </div>
      <div class="skill-archive section-frame-body">
        {
          stacks.map((stackGroup) => (
            <section class="skill-group-card">
              <div class="skill-group-copy">
                <h3>{stackGroup.group}</h3>
                <p>{stackGroup.summary}</p>
              </div>
              <div class="skill-chip-list">
                {stackGroup.items.map((item) => (
                  <span class="skill-tile">
                    <SkillLogo name={item} />
                    <span>{item}</span>
                  </span>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section projects-section" id="projects">
    <div class="container section-frame">
      <div class="section-heading section-frame-heading">
        <span class="section-number">03.</span>
        <p class="eyebrow">Selected projects</p>
        <h2>프로젝트</h2>
        <p>문제 정의와 백엔드 설계 판단을 상세 페이지로 정리했습니다.</p>
      </div>
      <div class="project-board section-frame-body">
        {projects.slice(0, 3).map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
